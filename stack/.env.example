# Clawtilla compose env. Copy to `.env` and adjust.
COMPOSE_PROJECT_NAME=clawtilla

# Gateway dashboard publish on the Mac loopback (host port -> container 8080).
# Hardcoded as 127.0.0.1:5182:8080 in compose.yaml; kept here for reference.

# The agent that runs inside a ClawBot. The stack uses curl + a shell as the test
# "agent" and validates NETWORK isolation only. Launch it with the `run`
# wrapper, which sets the CA-bundle + placeholder-token env (plain join does
# not install a shell rc — see Dockerfile / F1):
#   docker compose exec -it clawbot-418 run '<agent>'
