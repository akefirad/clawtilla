# clawpatrol gateway secrets — TEMPLATE.
#
# Copy to gateway.env, fill in the real values, then flash the gateway and run
# deploy-gateway-bundle.sh (it stages gateway.env onto the card's boot partition;
# first boot installs it to /etc/clawpatrol/gateway.env root-owned 0600 and wipes
# it off the FAT partition).
#
# DO NOT commit the filled-in gateway.env — these are secrets (gitignored, same
# handling as the WiFi PSK). This .example (placeholders only) is safe to commit.

# Gateway node auth key — Tailscale admin -> Settings -> Keys.
# Tag: tag:clawgateway. Ephemeral OFF, Pre-approved ON, Reusable ON.
TS_AUTHKEY=tskey-auth-REPLACE_ME

# OAuth client — Tailscale admin -> Settings -> OAuth clients.
# Scopes: write on Auth Keys + read on Devices. Tag: tag:clawbot.
TS_OAUTH_CLIENT_ID=REPLACE_ME
TS_OAUTH_CLIENT_SECRET=tskey-client-REPLACE_ME
