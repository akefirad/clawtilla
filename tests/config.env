# shellcheck shell=bash
# Clawtilla verification — tunable configuration.
# Sourced by lib/common.sh. Every value can also be overridden by exporting it
# in the environment before running. Keep this in sync with stack/compose.yaml
# and stack/gateway.hcl (the runtime tests assert against these targets).

# --- compose / project ------------------------------------------------------
# Docker Compose project name for the VERIFICATION stack. Kept intentionally
# DISTINCT from the stack's own top-level `name:` so the test stack lives in
# its own namespace (clawtilla-verify_* networks/volumes, clawtilla-verify-*
# images and containers). This is what stops `run.sh` from ever colliding with
# or tearing down a real deployment of the same stack (e.g. a production
# stack named `clawtilla`). Every compose call in the harness passes `-p`.
PROJECT=clawtilla-verify
# COMPOSE_FILE defaults to <repo>/stack/compose.yaml; override if relocated.
GATEWAY_SVC=gateway
TBOT_SVC=clawbot-418
TBOT_HOST=clawbot-418

# --- dashboard / gateway ----------------------------------------------------
# DASH_HOST_PORT is the dashboard port the STACK publishes by default
# (verified by the static port check). The live verification stack instead
# publishes on a RANDOM loopback port — runtime/00_bringup.sh exports the
# stack's own CLAWTILLA_DASH_PORT=0 before bring-up so it never collides with
# a real deployment on 5182, then discovers the actual port and derives
# DASH_HOST_URL from it. Export CLAWTILLA_DASH_PORT to pin a fixed test port, or
# DASH_HOST_URL to point the harness at an already-running stack.
DASH_HOST_PORT=5182
# As seen from inside a ClawBot (Docker DNS alias on clawcage-net).
GW_INTERNAL_URL=http://gateway:8080

# Dashboard root password. TEST-ONLY default (>=12 chars, clawpatrol minimum).
# In any real deployment use a strong random secret and DO NOT commit it.
DASH_PW=clawtilla-verify-pw-1

# --- policy test targets (must match stack/gateway.hcl) ------------------
# In-scope endpoint that is MITM'd + rule-evaluated (echo endpoint, bound via
# the echo-dummy credential). Used for allow/deny + credential-injection tests.
ALLOWED_MITM_HOST=postman-echo.com
ALLOWED_MITM_GET_URL=https://postman-echo.com/get
ALLOWED_MITM_POST_URL=https://postman-echo.com/post

# A host NOT bound to the default profile -> transparent relay (passthrough).
# Proves the "monitor-only, not default-deny" behaviour (design N1 / review I1).
RELAY_HOST=example.com
RELAY_URL=https://example.com/

# The plaintext secret wired via CLAWPATROL_SECRET_ECHO_DUMMY in compose.yaml.
SECRET_PLAINTEXT=test-secret-123

# --- adversarial / known-gap probes (review F1, F2, F6) ---------------------
# F1: the host-gateway name + cloud metadata IP the promiscuous relay can be
# coaxed into dialing. The host-gateway IP is resolved at runtime from the
# gateway side; this is the fallback name and the metadata literal.
HOST_GATEWAY_NAME=host.docker.internal
METADATA_IP=169.254.169.254
# F2: an external name used to test whether the cage can resolve it (a DNS
# exfil/C2 channel that need not traverse the gateway).
DNS_PROBE_NAME=example.com
# F6: hosts whose endpoints REFLECT request headers back in the response body —
# binding a real credential to any of these defeats "secrets stay at the gateway".
REFLECTING_HOSTS="postman-echo.com httpbin.org requestbin"

# --- resilience (client<->gateway link can be briefly unstable) -------------
# Network-dependent positive checks retry transient failures before failing.
# A definite HTTP status (e.g. a 403 deny) is honored immediately and never
# retried, so policy assertions stay exact; only connection failures retry.
RETRY_ATTEMPTS=4    # total attempts per flaky network check
RETRY_DELAY=3       # seconds between attempts
CURL_MAX_TIME=20    # per-request curl timeout (seconds)
